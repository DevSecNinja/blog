{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      customType: "regex",
      description: "Process tool versions in GitHub Actions workflows",
      managerFilePatterns: ["/.github/workflows/.+\\.ya?ml$/"],
      matchStrings: [
        "# renovate: datasource=github-releases depName=(?<depName>\\S+)\\n\\s+version: (?<currentValue>[^\\s]+)",
      ],
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      description: "Process min_version in .mise.toml",
      managerFilePatterns: ["/\\.mise\\.toml$/"],
      matchStrings: [
        "# renovate: datasource=github-releases depName=(?<depName>\\S+)\\nmin_version = \"(?<currentValue>[^\"]+)\"",
      ],
      datasourceTemplate: "github-releases",
    },
  ],
}
